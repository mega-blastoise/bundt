{
  "name": "@bundt/root",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "internal/*"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "packageManager": "bun@1.3.9",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2.7.5",
    "typescript": "^5.9.0"
  }
}
