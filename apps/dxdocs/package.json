{
  "name": "@bundt/dxdocs",
  "version": "0.1.0-alpha.1",
  "type": "module",
  "description": "Beautiful documentation sites from MDX. Zero client JS, pure static HTML.",
  "license": "MIT",
  "bin": {
    "dxdocs": "./dist/dxdocs.mjs",
    "bun-dxdocs": "./bin/dxdocs.ts"
  },
  "keywords": [
    "documentation",
    "mdx",
    "static-site-generator",
    "docs",
    "bun",
    "react",
    "ssg"
  ],
  "exports": {
    ".": {
      "bun": "./dist/index.bun.js",
      "import": "./dist/index.bun.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.bun.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "src",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun run src/cli.ts dev",
    "build:site": "bun run src/cli.ts build",
    "prebuild": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:bundle": "bun build/index.ts",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist site"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "cac": "^6.7.0",
    "chokidar": "^4.0.0",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "@mdx-js/mdx": "^3.1.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.575.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.0.0",
    "unist-util-visit": "^5.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*",
    "@bundt/internal-node-shim": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/unist": "^3.0.3",
    "typescript": "^5.9.0"
  }
}
