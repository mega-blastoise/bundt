{
  "name": "@bundt/cleo",
  "version": "0.1.0",
  "type": "module",
  "description": "Claude extensions orchestrator. Manage, run, and share Claude Code agents and skills.",
  "license": "MIT",
  "bin": {
    "cleo": "./bin/cleo.mjs",
    "bun-cleo": "./bin/cleo.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "skills",
    "cli",
    "bun",
    "ai"
  ],
  "exports": {
    ".": {
      "bun": "./dist/cli.bun.js",
      "import": "./dist/cli.bun.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/cli.bun.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "resources",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "prebuild": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:bundle": "bun build/index.ts",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "prerelease-check": "./scripts/prerelease-check.sh"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "cac": "^6.7.0",
    "front-matter": "^4.0.2",
    "fuse.js": "^7.1.0",
    "marked": "^17.0.3",
    "picocolors": "^1.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
