{
  "name": "@bundt/cleo",
  "version": "0.1.0-alpha.0",
  "type": "module",
  "description": "Claude extensions orchestrator. Manage, run, and share Claude Code agents and skills.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mega-blastoise/bundt.git",
    "directory": "apps/cleo"
  },
  "homepage": "https://github.com/mega-blastoise/bundt/tree/main/apps/cleo",
  "bugs": {
    "url": "https://github.com/mega-blastoise/bundt/issues"
  },
  "bin": {
    "cleo": "./dist/cleo.mjs",
    "bun-cleo": "./bin/cleo.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "agents",
    "skills",
    "cli",
    "bun",
    "ai",
    "mcp",
    "orchestrator"
  ],
  "exports": {
    ".": {
      "bun": "./dist/cli.bun.js",
      "import": "./dist/cli.bun.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/cli.bun.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "resources",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "alpha"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "prebuild": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:bundle": "bun build/index.ts",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@bit-context-protocol/driver": "^0.1.0-alpha.0",
    "@inquirer/prompts": "^8.3.0",
    "cac": "^6.7.0",
    "front-matter": "^4.0.2",
    "fuse.js": "^7.1.0",
    "marked": "^17.0.3",
    "picocolors": "^1.1.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*",
    "@bundt/internal-node-shim": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
