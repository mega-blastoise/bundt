{
  "name": "@bundt/ollama",
  "version": "0.1.0",
  "type": "module",
  "description": "Run Claude Code with local Ollama LLMs. Zero API costs, complete privacy.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mega-blastoise/bundt.git",
    "directory": "apps/ollama"
  },
  "homepage": "https://github.com/mega-blastoise/bundt/tree/main/apps/ollama",
  "bugs": {
    "url": "https://github.com/mega-blastoise/bundt/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "ollama-bundt": "./dist/ollama.mjs",
    "bun-ollama": "./bin/ollama.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ollama",
    "llm",
    "local-llm",
    "ai-coding",
    "cli",
    "bun"
  ],
  "exports": {
    ".": {
      "bun": "./dist/cli.bun.js",
      "import": "./dist/cli.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "docker",
    "post-install.js",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "prebuild": "rm -rf dist",
    "build:types": "tsc -p tsconfig.build.json",
    "build:bundle": "bun build/index.ts",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist",
    "postinstall": "node post-install.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "bytes": "^3.1.2",
    "cac": "^6.7.14",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*",
    "@bundt/internal-node-shim": "workspace:*",
    "@types/bun": "latest",
    "@types/bytes": "^3.1.5",
    "@types/node": "^25.0.0",
    "typescript": "^5.9.0"
  }
}
