{
  "name": "@bundt/hateoas",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Modern minimal React HATEOAS REST framework.",
  "license": "MIT",
  "keywords": [
    "hateoas",
    "rest",
    "hypermedia",
    "react",
    "bun"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./client": "./src/client/index.ts",
    "./react": "./src/react/index.ts",
    "./protocol": "./src/protocol/index.ts"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "bun run dev:server & bun run dev:client",
    "dev:server": "bun run example/server.ts",
    "dev:client": "bun run example/dev.ts",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "typescript": "^5.9.0"
  }
}
