{
  "name": "@bundt/hateoas",
  "version": "0.1.0",
  "type": "module",
  "description": "Modern minimal React HATEOAS REST framework.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mega-blastoise/bundt.git",
    "directory": "packages/hateoas"
  },
  "homepage": "https://github.com/mega-blastoise/bundt/tree/main/packages/hateoas",
  "bugs": {
    "url": "https://github.com/mega-blastoise/bundt/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "hateoas",
    "rest",
    "hypermedia",
    "react",
    "bun"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "bun": "./src/server/index.ts",
      "import": "./dist/server.js",
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "bun": "./src/client/index.ts",
      "import": "./dist/client.js",
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client.js"
    },
    "./react": {
      "bun": "./src/react/index.ts",
      "import": "./dist/react.js",
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react.js"
    },
    "./protocol": {
      "bun": "./src/protocol/index.ts",
      "import": "./dist/protocol.js",
      "types": "./dist/protocol/index.d.ts",
      "default": "./dist/protocol.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build:bundle": "bun build/index.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "dev": "bun run dev:server & bun run dev:client",
    "dev:server": "bun run example/server.ts",
    "dev:client": "bun run example/dev.ts",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*",
    "@types/bun": "latest",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.9.0"
  }
}
