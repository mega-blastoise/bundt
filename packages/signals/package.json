{
  "name": "@bundt/signals",
  "version": "0.1.0",
  "type": "module",
  "description": "Reactive signal graph abstractions — signals, computed values, and effects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mega-blastoise/bundt.git",
    "directory": "packages/signals"
  },
  "homepage": "https://github.com/mega-blastoise/bundt/tree/main/packages/signals",
  "bugs": {
    "url": "https://github.com/mega-blastoise/bundt/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "latest"
  },
  "keywords": [
    "signals",
    "reactive",
    "computed",
    "effects",
    "state",
    "bun"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "engines": {
    "bun": ">=1.3"
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build:bundle": "bun build/index.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*",
    "@types/bun": "latest",
    "typescript": "^5.9.0"
  }
}
