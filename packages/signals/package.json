{
  "name": "@bundt/signals",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "description": "Signal graph abstractions.",
  "license": "MIT",
  "engines": {
    "bun": ">=1.3"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "prebuild": "rm -rf dist",
    "build:bundle": "bun build/index.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "bun run build:bundle && bun run build:types",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@bundt/internal-build-utils": "workspace:*"
  }
}
